# 应用启动地址
APP_HOST=0.0.0.0
APP_PORT=3000
DISABLE_HMR=true

# local 环境
# 对应命令：
# npm run dev
# npm run build:local
# npm run start:local

# MQTT Broker（本地/线上统一，详见 .env.local / .env.dev）
MQTT_URL=ws://47.115.212.129:8083/mqtt
MQTT_USERNAME=zdzn
MQTT_PASSWORD=zdzn@1234

# 各车间 MQTT 主题（完整映射见 mqttTopics.config.ts）
# 聚铝老厂
MQTT_TOPIC_JL_OLD=/JH/sensor/JLLC/pub
# 新聚铝液位
MQTT_TOPIC_XJLYW=/JH/sensor/XJLYW/pub
# 新聚铝反应
MQTT_TOPIC_XJLFY=/JH/sensor/XJLFY/pub
# 聚铝新厂干燥
MQTT_TOPIC_JLXCGZ=/JH/sensor/JLXCGZ/pub
# 低铁硫酸铝
MQTT_TOPIC_DTLSL=/JH/sensor/DTLSL/pub
# 聚合硫酸铁
MQTT_TOPIC_JLLST=/JH/sensor/JLLST/pub
# 液体硫酸铝
MQTT_TOPIC_YTLSL=/JH/sensor/YTLSL/pub
# 明矾车间
MQTT_TOPIC_MFCJ=/JH/sensor/MFCJ/pub
